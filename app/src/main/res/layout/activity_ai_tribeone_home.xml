<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary">

    <FrameLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <!-- Top Gradient Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:padding="@dimen/margin15"
        android:background="@color/colorPrimary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Story Hub"
            android:textSize="@dimen/font20"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose an option to get started"
            android:textSize="@dimen/font14"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Card Container -->
    <LinearLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/margin35"
        android:paddingStart="@dimen/margin10"
        android:paddingEnd="@dimen/margin10"
        android:layout_marginTop="@dimen/margin90"
        android:background="@drawable/bg_top_rounded_white">

        <!-- Reusable Card -->
        <!-- Create Questionnaire -->
        <include layout="@layout/item_story_option"
            android:id="@+id/createQuestionnaire"
            android:tag="Create Questionnaire"/>

        <!-- Upload Story -->
        <include layout="@layout/item_story_option"
            android:id="@+id/uploadStory"
            android:tag="Upload Story"/>

        <!-- Upload Story -->
        <include layout="@layout/item_story_option"
            android:id="@+id/manageStory"
            android:tag="Manage Uploaded Story"/>

        <!-- General Talk -->
        <include layout="@layout/item_story_option"
            android:id="@+id/generalTalk"
            android:tag="General Talk"/>

        <!-- Manual Entry -->
        <include layout="@layout/item_story_option"
            android:id="@+id/manualEntry"
            android:tag="Manual Entry"
            android:visibility="gone"/>

    </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>