<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.CommunityMainActivity">

    <!-- App Header -->
    <RelativeLayout
        android:id="@+id/app_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <TextView
            android:id="@+id/bl_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Manage User Story"
            android:layout_marginBottom="@dimen/margin5"
            android:textColor="@color/white"
            android:textSize="@dimen/font20"
            android:textStyle="bold" />


    </RelativeLayout>

    <LinearLayout
        android:id="@+id/meeting_title_ll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/app_header"
        android:orientation="vertical"
        android:padding="@dimen/margin5">

        <LinearLayout
            android:id="@+id/meeting_members_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/list_member_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#80018786"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="1"
                android:text="List of all users previous story"
                android:textColor="@color/blue"
                android:textSize="@dimen/font16"
                android:layout_margin="@dimen/margin10"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/meeting_users_rv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/margin5"
                tools:itemCount="10"/>
        </LinearLayout>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>