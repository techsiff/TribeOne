<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_items"
    android:layout_width="@dimen/home_grid_icon"
    android:layout_height="@dimen/home_grid_icon"
    android:layout_margin="@dimen/margin5"
    app:cardCornerRadius="@dimen/margin5"
    app:cardElevation="@dimen/margin3">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_background"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/menu_image"
            android:layout_width="@dimen/margin75"
            android:layout_height="@dimen/margin75"
            android:layout_centerVertical="true"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_education" />

        <TextView
            android:id="@+id/menu_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:layout_centerInParent="true"
            android:maxLines="1"
            android:text="@string/education_title"
            android:textColor="@color/blue"
            android:textSize="@dimen/font12"
            android:textStyle="bold" />
    </RelativeLayout>

</androidx.cardview.widget.CardView>