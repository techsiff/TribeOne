<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin5"
    card_view:cardBackgroundColor="@color/white"
    card_view:cardCornerRadius="@dimen/margin10"
    card_view:cardElevation="@dimen/margin3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/margin15">

        <!-- Icon Background -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="@dimen/margin45"
            android:layout_height="@dimen/margin45"
            android:background="@drawable/bg_icon_circle"
            android:padding="@dimen/margin10">

            <ImageView
                android:id="@+id/icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                card_view:tint="@android:color/white" />
        </FrameLayout>

        <!-- Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin10"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="@color/intro_title"
                android:textSize="@dimen/font16"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin4"
                android:text="Subtitle"
                android:textColor="@color/intro_desc"
                android:textSize="@dimen/font13" />
        </LinearLayout>

        <!-- Arrow -->
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_forward"
            card_view:tint="#B0B0B0" />

    </LinearLayout>

</androidx.cardview.widget.CardView>