<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/notes_edit"
            android:layout_marginTop="@dimen/margin10"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin10"
                android:text="Notes"
                android:textColor="@color/blue"
                android:textSize="@dimen/font18"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/notes_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/margin10"
                android:layout_marginRight="@dimen/margin10"
                tools:itemCount="20"
                android:visibility="gone"
                tools:listitem="@layout/list_item_notes_details" />

        </LinearLayout>

        <TextView
            android:id="@+id/no_notes_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No notes data available"
            android:layout_centerInParent="true"
            android:textColor="@color/blue"
            android:textSize="@dimen/font20"
            android:visibility="gone"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/notes_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top|start"
            android:scrollbars="vertical"
            android:minLines="1"
            android:layout_marginStart="@dimen/margin10"
            android:layout_marginEnd="@dimen/margin10"
            android:imeOptions="actionDone"
            android:background="@drawable/notes_edit_text_border"
            android:backgroundTint="@color/colorAccent"
            android:hint="@string/notes_edit"
            android:paddingStart="@dimen/margin10"
            android:textColor="@color/blue"
            android:textColorHint="@color/grey"
            android:textSize="@dimen/font16"
            android:visibility="gone"
            android:layout_alignParentBottom="true"
            tools:ignore="RtlSymmetry" />

    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>