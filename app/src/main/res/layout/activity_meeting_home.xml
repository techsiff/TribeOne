<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.CommunityMainActivity">

    <!-- App Header -->
    <RelativeLayout
        android:id="@+id/app_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnTags"
            android:layout_width="@dimen/margin30"
            android:layout_height="@dimen/margin30"
            android:layout_alignParentStart="true"
            android:layout_marginStart="@dimen/margin10"
            android:src="@drawable/ic_tags" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Meeting Rooms"
            android:layout_marginBottom="@dimen/margin5"
            android:textColor="@color/white"
            android:textSize="@dimen/font20"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnBlocking"
            android:layout_width="@dimen/margin30"
            android:layout_height="@dimen/margin30"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="@dimen/margin10"
            android:src="@drawable/ic_block" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/app_header"
        app:layout_constraintBottom_toTopOf="@id/btnNewMeetingRoomLL"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Available Meeting Rooms"
            android:layout_margin="@dimen/margin10"
            android:textColor="@color/blue"
            android:textSize="@dimen/font16"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/meetings_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/margin3"
            android:layout_marginEnd="@dimen/margin3"
            android:layout_weight="1"
            tools:itemCount="16"
            tools:listitem="@layout/list_item_mettings" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnNewMeetingRoomLL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin5"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnNewMeetingRoom"
            style="@style/MyCustomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/margin20"
            android:layout_marginRight="@dimen/margin20"
            android:background="@drawable/button_bg"
            android:text="Create New Room"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:letterSpacing="0"
            android:textSize="@dimen/font20" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>